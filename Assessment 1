    <!-- Recipe Header -->
    <article>
        <h1>Jollof Rice Recipe</h1>

        <p>
            Jollof Rice is a popular West African dish made with rice,
            tomatoes, peppers, and spices. It is flavorful, delicious,
            and perfect for family meals and celebrations.
        </p>

        <!-- Recipe Details -->
        <section>
            <h2>Recipe Details</h2>
            <p><strong>Prep Time:</strong> 20 minutes</p>
            <p><strong>Cook Time:</strong> 45 minutes</p>
            <p><strong>Servings:</strong> 6 people</p>
            <p><strong>Difficulty:</strong> <em>Easy</em></p>
        </section>

        <!-- Recipe Image -->
        <section>
            <h2>Recipe Image</h2>
            <img src="jollof-rice.jpg"
                 alt="A plate of delicious Jollof Rice"
                 width="400"
                 height="300">
        </section>

        <!-- Ingredients -->
        <section>
            <h2>Ingredients</h2>
            <ul>
                <li>2 cups long-grain rice</li>
                <li>4 tomatoes</li>
                <li>2 red bell peppers</li>
                <li>1 onion</li>
                <li>2 tablespoons vegetable oil</li>
                <li>2 seasoning cubes</li>
                <li>1 teaspoon curry powder</li>
                <li>Salt to taste</li>
            </ul>
        </section>

        <!-- Instructions -->
        <section>
            <h2>Instructions</h2>
            <ol>
                <li>Wash the rice thoroughly and set aside.</li>
                <li>Blend the tomatoes, peppers, and half of the onion.</li>
                <li>Heat oil in a pot and fry the chopped onion until soft.</li>
                <li>Add the blended mixture and cook for 10–15 minutes.</li>
                <li>Add seasoning, curry powder, and salt.</li>
                <li>Add the rice and enough water, then stir well.</li>
                <li>Cover and cook until the rice is soft and the water is absorbed.</li>
            </ol>
        </section>

        <!-- Tips Section -->
        <section>
            <h2>Tips</h2>
            <p>
                <mark>For extra flavor</mark>, use chicken stock instead of water.
                You can also add vegetables or grilled chicken as side dishes.
            </p>
            <p>
                <u>Do not overcook the rice</u> to maintain the best texture.
            </p>
        </section>

